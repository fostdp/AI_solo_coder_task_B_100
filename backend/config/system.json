{
  "version": "1.1.0",
  "description": "轒辒车结构防护仿真系统 - 全局系统配置",
  "http": {
    "host": "0.0.0.0",
    "port": 8080,
    "max_request_size_bytes": 65536
  },
  "clickhouse": {
    "host": "127.0.0.1",
    "http_port": 8123,
    "tcp_port": 9000,
    "user": "default",
    "password": "",
    "database": "fenyun_vehicle",
    "connection_timeout_ms": 3000
  },
  "mqtt": {
    "broker_url": "tcp://127.0.0.1:1883",
    "client_id": "fenyun_backend",
    "username": "",
    "password": "",
